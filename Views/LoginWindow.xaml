<!-- Views/LoginWindow.xaml -->
<Window x:Class="OGAS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:uc="clr-namespace:OGAS.Controls"
        xmlns:helpers="clr-namespace:OGAS.Services"
        xmlns:vm="clr-namespace:OGAS.ViewModels"
        Title="Login" Height="720" Width="1280" Background="Transparent" ResizeMode="NoResize" AllowsTransparency="True" WindowStyle="None" WindowStartupLocation="CenterScreen" >

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#cfd5e5" CornerRadius="40" BorderThickness="2" BorderBrush="#ebedf3" Padding="20" MouseDown="Border_MouseDown">
        <Border CornerRadius="40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#fefefe" Offset="0"/>
                    <GradientStop Color="#ededef" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Column="1" Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>

                    <!-- 登录按钮 -->
                    <Button Command="{Binding LoginCommand}" Background="Transparent" BorderBrush="Transparent" Padding="0" Grid.Column="1" Grid.Row="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#7163ba" CornerRadius="30" BorderBrush="#ebedf3" BorderThickness="2">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" Width="182">
                                        <Border Background="#8d82c8" CornerRadius="22" Width="65" Height="65" Margin="12" BorderThickness="1" BorderBrush="#aea6d8">
                                            <Icon:PackIconMaterial Kind="Login" Width="30" Height="30" HorizontalAlignment="Center" Foreground="White" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="登录" FontSize="35" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- 用户名输入 -->
                <Border CornerRadius="30" Background="#7163ba" Grid.Column="1" Grid.Row="1">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#8d82c8" CornerRadius="22" Width="70" Height="70" Margin="17" BorderThickness="1" BorderBrush="#aea6d8">
                            <Icon:PackIconMaterial Kind="Account" Width="34" Height="34" HorizontalAlignment="Center" Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                        <TextBox x:Name="UsernameTextBox"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="35" 
                                 FontWeight="SemiBold" 
                                 Foreground="White" 
                                 VerticalAlignment="Center" 
                                 Background="Transparent" 
                                 Width="700"/>
                    </StackPanel>
                </Border>

                <!-- 密码输入 -->
                <Border CornerRadius="30" Background="#7163ba" Grid.Column="1" Grid.Row="3">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#8d82c8" CornerRadius="22" Width="70" Height="70" Margin="17" BorderThickness="1" BorderBrush="#aea6d8">
                            <Icon:PackIconMaterial Kind="Lock" Width="34" Height="34" HorizontalAlignment="Center" Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                        <PasswordBox x:Name="PasswordBox"
                                     Margin="0,0,0,0" 
                                     FontSize="35" 
                                     FontWeight="SemiBold" 
                                     Foreground="White" 
                                     VerticalAlignment="Center" 
                                     Background="Transparent" 
                                     Width="700" 
                                     helpers:PasswordBoxAssistant.BindPassword="True" 
                                     helpers:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  />

                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
