<!-- Views/Plan.xaml -->
<Page x:Class="OGAS.Views.Plan"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:oxy="http://oxyplot.org/wpf"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:OGAS.ViewModels" 
      xmlns:co="clr-namespace:OGAS.Converters"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      Title="Plan" Height="700" Width="1000">

    <Grid>
        <!-- 标题 -->
        <TextBlock Text="生产计划管理" FontSize="24" FontWeight="Bold" Margin="10" HorizontalAlignment="Center" />
        <Grid Margin="0,50,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：生产计划列表 -->
            <DataGrid ItemsSource="{Binding 生产计划集合}" 
                      SelectedItem="{Binding 选中生产计划, Mode=TwoWay}" 
                      Grid.Column="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True" 
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="计划ID" Binding="{Binding 计划ID}" Visibility="Collapsed" />
                    <DataGridTextColumn Header="计划类型" Binding="{Binding 计划类型}" />
                    <DataGridTextColumn Header="工艺" Binding="{Binding 生产工艺.工艺名称}" />
                    <DataGridTextColumn Header="加工厂" Binding="{Binding 加工厂.名称}" />
                    <DataGridTextColumn Header="计划数量" Binding="{Binding 计划数量}" />
                    <DataGridTextColumn Header="开始日期" Binding="{Binding 计划开始日期, StringFormat=d}" />
                    <DataGridTextColumn Header="状态" Binding="{Binding 状态}" />
                    <DataGridTextColumn Header="备注" Binding="{Binding 备注}" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- 右侧：生产计划表单 -->
            <ScrollViewer Grid.Column="1" Margin="10,0,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 计划类型 -->
                    <TextBlock Text="计划类型：" Margin="0,0,0,5" />
                    <ComboBox SelectedItem="{Binding 计划类型, UpdateSourceTrigger=PropertyChanged}" 
                              SelectionChanged="计划类型ComboBox_SelectionChanged" 
                              Margin="0,0,0,10">
                        <ComboBox.ItemsSource>
                            <x:Array Type="{x:Type sys:String}">
                                <sys:String>生产</sys:String>
                            </x:Array>
                        </ComboBox.ItemsSource>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <!-- 工艺选择 -->
                    <TextBlock Text="工艺：" Margin="0,10,0,5" />
                    <ComboBox ItemsSource="{Binding 工艺列表}" 
                              SelectedItem="{Binding 选中工艺, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="工艺名称" 
                              SelectedValuePath="工艺ID" 
                              Margin="0,0,0,10">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <!-- 加工厂选择 -->
                    <TextBlock Text="加工厂：" Margin="0,10,0,5" />
                    <ComboBox ItemsSource="{Binding 加工厂列表}" 
                              SelectedItem="{Binding 选中加工厂, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="名称" 
                              SelectedValuePath="加工厂ID" 
                              Margin="0,0,0,10">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <!-- 计划数量 -->
                    <TextBlock Text="计划生产数量：" Margin="0,10,0,5" />
                    <TextBox Text="{Binding 计划数量, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,10" />

                    <!-- 计划开始日期 -->
                    <TextBlock Text="计划开始日期：" Margin="0,10,0,5" />
                    <DatePicker SelectedDate="{Binding 计划开始日期, UpdateSourceTrigger=PropertyChanged}" 
                                Margin="0,0,0,10" />

                    <!-- 状态 -->
                    <TextBlock Text="状态：" Margin="0,10,0,5" />
                    <ComboBox SelectedItem="{Binding 计划状态, UpdateSourceTrigger=PropertyChanged}" 
                              Margin="0,0,0,10">
                        <ComboBox.ItemsSource>
                            <x:Array Type="{x:Type sys:String}">
                                <sys:String>未开始</sys:String>
                                <sys:String>已完成</sys:String>
                                <sys:String>已取消</sys:String>
                            </x:Array>
                        </ComboBox.ItemsSource>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <!-- 备注 -->
                    <TextBlock Text="备注：" Margin="0,10,0,5" />
                    <TextBox Text="{Binding 计划备注, UpdateSourceTrigger=PropertyChanged}" 
                             AcceptsReturn="True" 
                             Height="60" 
                             Margin="0,0,0,10" />

                    <!-- 操作按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="保存" Command="{Binding 保存生产计划Command}" Width="80" Margin="5" />
                        <!--<Button Content="更新" Command="{Binding 更新生产计划Command}" Width="80" Margin="5" />-->
                        <Button Content="删除" Command="{Binding 删除生产计划Command}" Width="80" Margin="5" />
                        <Button Content="重置" Command="{Binding 重置生产计划Command}" Width="80" Margin="5" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
