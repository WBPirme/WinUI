<!-- MainWindow.xaml -->
<Window x:Class="OGAS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:OGAS.Services"
        Height="760" Width="1280" Background="Transparent" ResizeMode="NoResize" AllowsTransparency="True" WindowStyle="None" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#cfd5e5" CornerRadius="40" BorderThickness="2" BorderBrush="#ebedf3" Padding="20" MouseDown="Border_MouseDown">
        <Border CornerRadius="40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#fefefe" Offset="0"/>
                    <GradientStop Color="#ededef" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧菜单 -->
                <Border CornerRadius="30" Background="#7163ba" Margin="20">
                    <Grid>
                        <StackPanel x:Name="StackPanel" VerticalAlignment="Top" >
                            <Button Style="{StaticResource topMenuButton}">
                                <Icon:PackIconMaterial Kind="BellCheckOutline" Style="{StaticResource menuButtonIcon}"/>
                            </Button>

                            <Separator Background="#877cc5" Margin="20 0 20 10" Height="0.8"/>

                            <Button Style="{StaticResource menuButton}" Tag="{x:Static local:PageKeys.Main}" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:PageKeys.Main}" Height="40" Background="{Binding SelectedPage, Converter={StaticResource PageToButtonBackgroundConverter}, ConverterParameter={x:Static local:PageKeys.Main}}">
                                <Icon:PackIconMaterial Kind="HomeVariant" Style="{StaticResource menuButtonIcon}"/>
                            </Button>
                            <Button Style="{StaticResource menuButton}" Tag="{x:Static local:PageKeys.DataCollection}" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:PageKeys.DataCollection}" Height="40" Background="{Binding SelectedPage, Converter={StaticResource PageToButtonBackgroundConverter}, ConverterParameter={x:Static local:PageKeys.DataCollection}}">
                                <Icon:PackIconMaterial Kind="FileDocumentEditOutline" Style="{StaticResource menuButtonIcon}"/>
                            </Button>
                            <Button Style="{StaticResource menuButton}" Tag="{x:Static local:PageKeys.Plan}" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:PageKeys.Plan}" Height="40" Background="{Binding SelectedPage, Converter={StaticResource PageToButtonBackgroundConverter}, ConverterParameter={x:Static local:PageKeys.Plan}}">
                                <Icon:PackIconMaterial Kind="Finance" Style="{StaticResource menuButtonIcon}"/>
                            </Button>
                            <Button Style="{StaticResource menuButton}" Tag="{x:Static local:PageKeys.Processing}" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:PageKeys.Processing}" Height="40" Background="{Binding SelectedPage, Converter={StaticResource PageToButtonBackgroundConverter}, ConverterParameter={x:Static local:PageKeys.Processing}}">
                                <Icon:PackIconMaterial Kind="Factory" Style="{StaticResource menuButtonIcon}"/>
                            </Button>
                            <Button Style="{StaticResource menuButton}" Tag="{x:Static local:PageKeys.Monitor}" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:PageKeys.Monitor}" Height="40" Background="{Binding SelectedPage, Converter={StaticResource PageToButtonBackgroundConverter}, ConverterParameter={x:Static local:PageKeys.Monitor}}">
                                <Icon:PackIconMaterial Kind="ClipboardCheckMultipleOutline" Style="{StaticResource menuButtonIcon}"/>
                            </Button>
                        </StackPanel>

                        <Separator Background="#877cc5" Margin="20 0 20 90" Height="0.8" VerticalAlignment="Bottom"/>

                        <Button Style="{StaticResource menuButton}" VerticalAlignment="Top" Margin="10,613,20,0" Command="{Binding LogoutCommand}" Height="38">
                            <Icon:PackIconMaterial Kind="LocationExit" Style="{StaticResource menuButtonIcon}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- 主内容区域 -->
                <Frame x:Name="MainFrame" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Source="Main.xaml" NavigationUIVisibility="Hidden"/>

            </Grid>
        </Border>
    </Border>
</Window>
