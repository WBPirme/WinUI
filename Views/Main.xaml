<Page x:Class="OGAS.Views.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OGAS.ViewModels"
      xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:uc="clr-namespace:OGAS.Controls"
      xmlns:oxy="http://oxyplot.org/wpf"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Main">

    <Page.Resources>
        <!-- 定义样式 -->
        <Style x:Key="titleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
        <Style x:Key="searchTextbox" TargetType="TextBox">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Margin" Value="30,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <!-- 主界面 -->
        <Grid Grid.Column="0" Margin="5 20 25 20">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 标题 -->
            <StackPanel Margin="7 10 0 25" Grid.ColumnSpan="3">
                <TextBlock Text="实验性" Foreground="#797295" FontSize="13"/>
                <TextBlock Text="资源管理和计划分配系统" Style="{StaticResource titleText}"/>
            </StackPanel>

            <!-- 搜索 -->
            <Grid Grid.Column="2" VerticalAlignment="Top" Margin="0 10 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <!-- 搜索框
                <Grid>
                    <TextBlock Margin="40 0 0 0" VerticalAlignment="Center" Foreground="#594f7f" IsHitTestVisible="False" Panel.ZIndex="1" Text="搜索..." Visibility="{Binding ElementName=txtSearch, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBox x:Name="txtSearch" Style="{StaticResource searchTextbox}"/>
                    <Icon:PackIconMaterial Kind="Magnify"  Width="14" Height="14" Foreground="#594f7f" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15 0 0 0"/>
                </Grid> -->

                <!-- 用户信息 -->
                <Ellipse Height="45" Width="45" Margin="15 0 7 0" Grid.Column="1">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="/images/1.jpeg"/>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>

            <!-- 主表界面 -->
            <Border Grid.Row="1" Grid.ColumnSpan="2" CornerRadius="30" Margin="0 0 20 50">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.1,1">
                        <GradientStop Color="#6a5dae" Offset="0"/>
                        <GradientStop Color="#54479c" Offset="1.2"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto "/>
                    </Grid.RowDefinitions>

                    <Border Background="#6e60b5" BorderThickness="2" BorderBrush="#8276c0" CornerRadius="30" Margin="0 0 0 -10"/>

                    <!-- 表标题 -->
                    <TextBlock Text="网络流量（kbps）" Foreground="#f0eff6" FontSize="12" FontWeight="SemiBold" Margin="32,6,322,164"/>

                    <!-- 网络流量图表 -->
                    <oxy:PlotView Grid.Row="0" Margin="0,10,0,127" Model="{Binding 网络流量图表}" Background="Transparent" Grid.RowSpan="2"/>
                    <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="10 20 10 15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 未开始计划 -->
                        <uc:TextInfo Grid.Column="0"  TextTop="{Binding 未开始计划百分比}" TextMiddle="{Binding 未开始计划数量}" TextBottom="未开始计划" />

                        <!-- 已开始计划 -->
                        <uc:TextInfo Grid.Column="1"  TextTop="{Binding 已开始计划百分比}" TextMiddle="{Binding 已开始计划数量}" TextBottom="已取消计划" />

                        <!-- 未完成计划 -->
                        <uc:TextInfo Grid.Column="2"  TextTop="{Binding 未完成计划百分比}" TextMiddle="{Binding 未完成计划数量}" TextBottom="已完成计划" />
                    </Grid>
                </Grid>
            </Border>

            <!-- 中右界面 -->
            <Grid Grid.Column="2" Grid.Row="1" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- 顶部小窗：出口收益 -->
                <Border CornerRadius="30" Background="#7163ba" Margin="10,0,10,10" Padding="10" Grid.Row="1" >
                    <StackPanel Orientation="Horizontal" >
                        <Border Background="#8d82c8" CornerRadius="18,18,18,18" Width="60" Height="58" Margin="17" BorderThickness="1" BorderBrush="#aea6d8">
                            <Icon:PackIconMaterial Kind="CurrencyUsd" Width="30" Height="30" HorizontalAlignment="Center" Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding 出口收益, StringFormat=外汇{0:C}}" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 按钮窗口：系统日志 -->
                <Border CornerRadius="30" Background="#e95e89" Grid.Row="2" Margin="10,20,10,49" ClipToBounds="True" >
                    <Border.Clip>
                        <RectangleGeometry RadiusX="30" RadiusY="30" Rect="0,0,271.9,250.45"/>
                    </Border.Clip>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border CornerRadius="30" Background="#fd91b3" VerticalAlignment="Center" BorderThickness="1" BorderBrush="#fc9cba">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,-1">
                                <Border Background="#feaec7" CornerRadius="25" Width="67" Height="68" Margin="20" BorderThickness="1" BorderBrush="#fec5d6">
                                    <Icon:PackIconMaterial Kind="Console" Width="35" Height="35" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"/>
                                </Border>

                                <TextBlock Text="系统日志" FontSize="20" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- 系统日志显示 -->
                        <TextBox Grid.Row="1" Text="{Binding 系统日志字符串}" Margin="20,10,20,10" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Background="Transparent" BorderBrush="Transparent" Grid.RowSpan="2" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 按钮信息卡片：固体库存、液体库存、气体库存 -->
            <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="10 20 10 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 产品库存 -->
                <uc:InfoCard Grid.Column="0" Desc="产品库存总数" Value="{Binding 产品库存总数}" Percentage="{Binding 产品库存占比}" Icon="Cube"/>

                <!-- 材料库存 -->
                <uc:InfoCard Grid.Column="1" Desc="材料库存总数" Value="{Binding 材料库存总数}" Percentage="{Binding 材料库存占比}" Icon="Water" />

                <!-- 出口总数 -->
                <uc:InfoCard Grid.Column="2" Desc="出口物品总数" Value="{Binding 出口物品总数}" Percentage="{Binding 出口百分比}" Icon="Cloud"/>
            </Grid>
        </Grid>

        <!--右界面-->
        <Border Background="White" Grid.Column="2" CornerRadius="0 40 40 0">
            <StackPanel>

                <!--顶部标题-->
                <Grid Margin="10 30 0 5">
                    <Icon:PackIconMaterial Kind="AccountGroupOutline" Style="{StaticResource titleIcon}"/>
                    <TextBlock Text="下级节点" Margin="40 0 0 0" Style="{StaticResource titleText}"/>
                    <Button Content="显示全部" Style="{StaticResource titleButton}"/>
                </Grid>

                <!--切换按钮-->
                <Border CornerRadius="20" Background="#ebecf0" Padding="0" Margin="20 15">
                    <Grid Margin="10 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="离线" Background="#7163ba" Foreground="White" Style="{StaticResource tabButton}"/>
                        <Button Content="在线" Grid.Column="1" Style="{StaticResource tabButton}"/>
                    </Grid>
                </Border>

                <!--用户信息-->
                <StackPanel>
                    <uc:UserCard FullName="节点1" Title="11" Time="111" Image="/images/2.jpg"/>
                    <uc:UserCard FullName="节点2" Title="22" Time="222" Image="/images/2.jpg"/>
                    <uc:UserCard FullName="节点3" Title="33" Time="333" Image="/images/2.jpg"/>
                    <uc:UserCard FullName="节点4" Title="44" Time="444" Image="/images/2.jpg"/>
                    <uc:UserCard FullName="节点5" Title="55" Time="555" Image="/images/2.jpg"/>
                </StackPanel>

                <Separator Background="#e7e5f3" Margin="20 15" Height="0.8"/>

                <!--按钮标题栏-->
                <Grid Margin="10 0 0 5">
                    <Icon:PackIconMaterial Kind="MapMarker" Style="{StaticResource titleIcon}"/>
                    <TextBlock Text="地图" Margin="40 0 0 0" Style="{StaticResource titleText}"/>
                    <Button Content="放大地图" Margin="0 3 15 0" Style="{StaticResource titleButton}"/>
                </Grid>

                <!--地图-->
                <Border CornerRadius="10" Height="125" Margin="25 10">
                    <Border.Background>
                        <ImageBrush ImageSource="/images/map.jpg"/>
                    </Border.Background>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>