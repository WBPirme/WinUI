<!-- Views/Processing.xaml -->
<Page x:Class="OGAS.Views.Processing"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:OGAS.ViewModels"
      Title="生产与分析">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 生产处理开关和暂停恢复按钮 -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10">
            <TextBlock Text="生产中勿动  " Height="16"/>
            <CheckBox Content="启用自动生产" IsChecked="{Binding IsAutoProductionEnabled}" Margin="0,0,10,0" IsEnabled="{Binding CanToggleAutoProduction}" Height="16" />
            <Button Content="暂停生产" Command="{Binding PauseProductionCommand}" Margin="0,0,10,0"/>
            <Button Content="恢复生产" Command="{Binding ResumeProductionCommand}" />
        </StackPanel>

        <!-- 进度条区域 -->
        <ScrollViewer Grid.Row="1" Margin="10" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ProductionProgressBars}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10" CornerRadius="5">
                            <StackPanel>
                                <!-- 显示生产计划名称 -->
                                <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <!-- 进度条 -->
                                <ProgressBar Value="{Binding CurrentProgress}" Height="20" Margin="0,0,0,5"  Maximum="1" Foreground="{Binding ProgressBarColor, Converter={StaticResource ColorToBrushConverter}}">
                                    <!-- 可选：添加动画或其他视觉效果 -->
                                </ProgressBar>
                                <!-- 显示剩余时间 -->
                                <TextBlock Text="{Binding RemainingTime}" FontStyle="Italic" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                <!-- 进度条排列方式 -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- 状态消息显示 -->
        <TextBlock Text="{Binding StatusMessage}" Grid.Row="2" Margin="10" FontWeight="Bold"/>
    </Grid>
</Page>
