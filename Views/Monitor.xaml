<!-- Views/Monitor.xaml -->
<Page x:Class="OGAS.Views.Monitor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:OGAS.Views"
      mc:Ignorable="d"
      Title="Monitor">

    <!-- DataContext 将在 Monitor.xaml.cs 中通过依赖注入设置 -->

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TabControl Margin="0,30,20,10">

            <!-- 库存管理 Tab -->
            <TabItem Header="库存管理">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <!-- 产品材料库存表单 -->
                        <RowDefinition Height="Auto"/>
                        <!-- 数据表格 -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 库存管理表单 -->
                    <GroupBox Header="库存管理" Grid.Row="0" Margin="5">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- 名称 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 产品类别 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 材料类别 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 数量 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 计量单位 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 备注 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 操作按钮和CheckBox -->
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 名称 (ComboBox) -->
                            <Label Content="名称:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Margin="5" 
                                      ItemsSource="{Binding NameOptions}"
                                      SelectedValue="{Binding SelectedName, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="ID"
                                      DisplayMemberPath="Name" />

                            <!-- 产品类别 -->
                            <Label Content="产品类别:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="5" 
                                      SelectedValue="{Binding ProductCategory, UpdateSourceTrigger=PropertyChanged}" 
                                      SelectedValuePath="Content">
                                <ComboBoxItem Content="原料"/>
                                <ComboBoxItem Content="加工产品"/>
                                <ComboBoxItem Content="制成品"/>
                            </ComboBox>

                            <!-- 材料类别 -->
                            <Label Content="材料类别:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="5" 
                                      SelectedValue="{Binding MaterialCategoryType, UpdateSourceTrigger=PropertyChanged}" 
                                      SelectedValuePath="Content">
                                <ComboBoxItem Content="有机"/>
                                <ComboBoxItem Content="金属"/>
                                <ComboBoxItem Content="无机非金属"/>
                            </ComboBox>

                            <!-- 数量 -->
                            <Label Content="数量:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="5" 
                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />

                            <!-- 计量单位 -->
                            <Label Content="计量单位:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Margin="5" 
                                      SelectedValue="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" 
                                      SelectedValuePath="Content">
                                <ComboBoxItem Content="吨"/>
                                <ComboBoxItem Content="升"/>
                                <ComboBoxItem Content="立方米"/>
                            </ComboBox>

                            <!-- 备注 -->
                            <Label Content="备注:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Margin="5" 
                                     Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" />

                            <!-- 操作按钮和CheckBox -->
                            <StackPanel Orientation="Horizontal" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="5">
                                <Button Content="保存" Width="75" Margin="5" 
                                        Command="{Binding SaveCommand}" />
                                <Button Content="更新" Width="75" Margin="5" 
                                        Command="{Binding UpdateCommand}" />
                                <Button Content="删除" Width="75" Margin="5" 
                                        Command="{Binding DeleteCommand}" />
                                <Button Content="重置" Width="75" Margin="5" 
                                        Command="{Binding ResetCommand}" />
                                <CheckBox Content="设置材料" Width="100" Margin="5" Height="15"  IsChecked="{Binding IsSetMaterialSelected}"/>
                                <CheckBox Content="设置产品" Width="100" Margin="5" Height="15"  IsChecked="{Binding IsSetProductSelected}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- 数据表格 -->
                    <Grid Grid.Row="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 产品库存 DataGrid -->
                        <DataGrid Grid.Column="0" AutoGenerateColumns="False" Margin="5"
                                  ItemsSource="{Binding ProductInventories}" 
                                  SelectedItem="{Binding SelectedProductInventory, Mode=TwoWay}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding 产品库存ID}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="产品名称" Binding="{Binding 产品.名称}" />
                                <DataGridTextColumn Header="产品类型" Binding="{Binding 产品类型}" />
                                <DataGridTextColumn Header="数量" Binding="{Binding 数量}" />
                                <DataGridTextColumn Header="计量单位" Binding="{Binding 计量单位}" />
                                <DataGridTextColumn Header="最后更新时间" Binding="{Binding 最后更新时间}" />
                                <DataGridTextColumn Header="备注" Binding="{Binding 备注}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 材料库存 DataGrid -->
                        <DataGrid Grid.Column="1" AutoGenerateColumns="False" Margin="5"
                                  ItemsSource="{Binding MaterialInventories}" 
                                  SelectedItem="{Binding SelectedMaterialInventory, Mode=TwoWay}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding 材料库存ID}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="材料名称" Binding="{Binding 材料.名称}" />
                                <DataGridTextColumn Header="材料类型" Binding="{Binding 材料类型}" />
                                <DataGridTextColumn Header="数量" Binding="{Binding 数量}" />
                                <DataGridTextColumn Header="计量单位" Binding="{Binding 计量单位}" />
                                <DataGridTextColumn Header="最后更新时间" Binding="{Binding 最后更新时间}" />
                                <DataGridTextColumn Header="备注" Binding="{Binding 备注}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="出口订单">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 出口订单表单 -->
                    <StackPanel Orientation="Vertical" Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Label Content="产品：" Width="100" VerticalAlignment="Center"/>
                            <ComboBox Width="200" 
                              ItemsSource="{Binding Products}" 
                              DisplayMemberPath="名称" 
                              SelectedValuePath="产品ID" 
                              SelectedValue="{Binding SelectedProductID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Label Content="出口数量：" Width="100" VerticalAlignment="Center"/>
                            <TextBox Width="200" 
                             Text="{Binding ExportQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Label Content="收益：" Width="100" VerticalAlignment="Center"/>
                            <TextBox Width="200" 
                             Text="{Binding Revenue, Mode=OneWay}" 
                             IsReadOnly="True" 
                             Background="LightGray"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 出口订单列表 -->
                    <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding ExportOrders}" 
                      SelectedItem="{Binding SelectedExportOrder}" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="订单ID" Binding="{Binding 订单ID}" Width="*"/>
                            <DataGridTextColumn Header="订单日期" Binding="{Binding 订单日期, StringFormat=yyyy-MM-dd}" Width="*"/>
                            <DataGridTextColumn Header="产品名称" Binding="{Binding 产品.名称}" Width="*"/>
                            <DataGridTextColumn Header="出口数量" Binding="{Binding 出口数量, StringFormat=N2}" Width="*"/>
                            <DataGridTextColumn Header="收益" Binding="{Binding 收益, StringFormat=N2}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 创建和重置按钮 -->
                    <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="创建出口订单" Width="150" 
                        Command="{Binding CreateExportOrderCommand}" 
                        Margin="0,0,10,0"/>
                        <Button Content="重置" Width="100" 
                        Command="{Binding ResetExportOrderCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </ScrollViewer>
</Page>
